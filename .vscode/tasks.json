{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run SocialDukaan Dev Server",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run SocialDukaan Dev Server (Debug)",
			"type": "shell",
			"command": "node",
			"args": [
				"--inspect",
				"./node_modules/next/dist/bin/next",
				"dev"
			],
			"isBackground": true,
			"group": "build"
		}
	]
}