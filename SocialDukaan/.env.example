NEXT_PUBLIC_APP_NAME=SocialDukaan
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# META (Facebook + Instagram) CREDENTIALS
# Get these from: https://developers.facebook.com/apps/
#
# Steps:
#  1. Create a new Meta App → "Business" type
#  2. Add products: "Facebook Login" + "Instagram Graph API"
#  3. Copy App ID and App Secret below
#  4. In Facebook Login settings, add:
#     Valid OAuth redirect URI: http://localhost:3000/api/auth/meta/callback
# ─────────────────────────────────────────────────────────────
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
