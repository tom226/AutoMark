NEXT_PUBLIC_APP_NAME=SocialDukaan
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# META (Facebook + Instagram) CREDENTIALS
# Get these from: https://developers.facebook.com/apps/
#
# Steps:
#  1. Create a new Meta App → "Business" type
#  2. Add products: "Facebook Login" + "Instagram Graph API"
#  3. Copy App ID and App Secret below
#  4. In Facebook Login settings, add:
#     Valid OAuth redirect URI: http://localhost:3000/api/auth/meta/callback
# ─────────────────────────────────────────────────────────────
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here

# LinkedIn OAuth
# Create app at: https://www.linkedin.com/developers/
# Redirect URI: http://localhost:3000/api/auth/linkedin/callback
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
# Scope options:
# 1) OpenID flow (recommended): openid profile email
# 2) Legacy Sign-In flow (only if your app has those products): r_liteprofile r_emailaddress
# Add posting scope only after LinkedIn approval: w_member_social
LINKEDIN_SCOPES=openid profile email

# Twitter / X OAuth 2.0
# Create app at: https://developer.x.com/
# Redirect URI: http://localhost:3000/api/auth/twitter/callback
TWITTER_CLIENT_ID=your_twitter_client_id_here
TWITTER_CLIENT_SECRET=your_twitter_client_secret_here
# Start with read scopes for authorization stability.
# Add tweet.write and offline.access only after enabling app permissions in X developer portal.
TWITTER_SCOPES=tweet.read users.read
